<html>
  <head>
    <meta charset="utf-8" />
    <title>Your OTP Verification</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f1f4f9;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
      }
      .ExternalClass {
        width: 100%;
      }
      img {
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
      }
    </style>
  </head>
  <body style="background-color: #f1f4f9;">
    <table
      border="0"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="table-layout: fixed; background-color: #f1f4f9;"
    >
      <tr>
        <td align="center">
          <table
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
            style="background: linear-gradient(135deg, #46b3e6 0%, #2e5da3 100%); background-color: #2e5da3; border-radius: 5px"
          >
            <tr>
              <td align="center" style="padding: 50px 0 10px 0;">
                <h1
                  style="color: #ffffff; font-size: 32px; letter-spacing: 5px; margin: 0; font-weight: 900; text-transform: uppercase; font-family: 'Inter', Arial, sans-serif;"
                >
                  TRAVEL LEDGER
                </h1>
                <p
                  style="color: rgba(255,255,255,0.8); font-size: 14px; margin-top: 12px; font-weight: 400; letter-spacing: 1px;"
                >
                  {{date}}
                </p>
              </td>
            </tr>
          </table>

          <table
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="95%"
            style="max-width: 600px; margin-top: 10px;"
          >
            <tr>
              <td
                align="center"
                style="background-color: #ffffff; border-radius: 24px; padding: 50px 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.05);"
              >
                <h2
                  style="color: #1f1f1f; font-size: 24px; margin: 0 0 15px 0;"
                >Your OTP</h2>
                <p
                  style="color: #4a4a4a; font-size: 16px; margin: 0 0 20px 0;"
                >Hey <strong>{{name}}</strong>,</p>

                <p
                  style="color: #718096; font-size: 14px; line-height: 1.6; margin: 0;"
                >
                  Thank you for choosing our service. Use the following OTP to
                  complete the procedure to change your email address. OTP is
                  valid for
                  <span style="color: #1f1f1f; font-weight: bold;">5 minutes</span>.
                  Do not share this code with others.
                </p>

                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" style="padding: 40px 0;">
                      <span
                        style="font-size: 42px; font-weight: 800; color: #cb4b5b; letter-spacing: 12px;"
                      >{{otp}}</span>
                    </td>
                  </tr>
                </table>

                <p style="color: #a0aec0; font-size: 12px; margin: 0;">
                  If you didn’t request this, please ignore this email.
                </p>

                <p style="color: #cbd5e0; font-size: 12px; margin-top: 40px;">
                  © 2026 Your Brand. All rights reserved.
                </p>
              </td>
            </tr>
          </table>

          <table border="0" cellpadding="0" cellspacing="0" width="100%">
            <tr><td height="50"></td></tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
