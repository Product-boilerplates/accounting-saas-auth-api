<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Your Two-Factor Authentication Code</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        background-color: #f5f7fa;
        color: #1e293b;
        line-height: 1.5;
        margin: 0;
        padding: 0;
      }

      .wrapper {
        max-width: 560px;
        margin: 0 auto;
        padding: 20px;
        background-color: #f5f7fa;
      }

      .container {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
      }

      .header {
        background: linear-gradient(145deg, #0f1825 0%, #1a2c3e 100%);
        padding: 36px 32px;
        text-align: center;
      }

      .header h1 {
        color: #ffffff;
        font-size: 26px;
        font-weight: 600;
        margin: 0;
        letter-spacing: -0.3px;
      }

      .header p {
        color: #94a3b8;
        font-size: 15px;
        margin-top: 8px;
      }

      .content {
        padding: 40px 32px;
      }

      .greeting {
        font-size: 18px;
        font-weight: 500;
        color: #1e293b;
        margin-bottom: 16px;
      }

      .greeting span {
        color: #2563eb;
        font-weight: 600;
      }

      .message {
        color: #475569;
        font-size: 15px;
        margin-bottom: 32px;
        line-height: 1.6;
      }

      .otp-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 32px 24px;
        margin: 32px 0;
        text-align: center;
      }

      .otp-label {
        color: #64748b;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 500;
        margin-bottom: 16px;
      }

      .otp-value {
        font-family:
          "SF Mono", "Monaco", "Inconsolata", "Fira Mono", "Droid Sans Mono",
          "Courier New", monospace;
        font-size: 48px;
        font-weight: 700;
        letter-spacing: 12px;
        color: #0f1825;
        margin: 8px 0;
        padding: 8px 0;
      }

      .otp-expiry {
        color: #ef4444;
        font-size: 13px;
        font-weight: 500;
        margin-top: 16px;
        background: #fef2f2;
        display: inline-block;
        padding: 6px 16px;
        border-radius: 40px;
      }

      .divider {
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          #e2e8f0,
          transparent
        );
        margin: 32px 0;
      }

      .alert-box {
        background: #fff7ed;
        border-radius: 16px;
        padding: 24px;
        margin: 24px 0;
      }

      .alert-title {
        color: #9a3412;
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .alert-title span {
        font-size: 20px;
      }

      .alert-list {
        color: #7b341e;
        font-size: 14px;
        padding-left: 24px;
        margin: 0;
      }

      .alert-list li {
        margin: 8px 0;
      }

      .help-text {
        color: #64748b;
        font-size: 14px;
        margin: 24px 0 0;
        padding: 16px 0 0;
        border-top: 1px dashed #e2e8f0;
      }

      .help-text a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
      }

      .help-text a:hover {
        text-decoration: underline;
      }

      .footer {
        background: #f8fafc;
        padding: 24px 32px;
        text-align: center;
        border-top: 1px solid #e2e8f0;
      }

      .footer-text {
        color: #94a3b8;
        font-size: 12px;
        margin: 4px 0;
      }

      .badge {
        background: #e6f7e6;
        color: #166534;
        padding: 4px 12px;
        border-radius: 40px;
        font-size: 12px;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 16px;
      }

      @media only screen and (max-width: 480px) {
        .wrapper {
          padding: 10px;
        }

        .content {
          padding: 30px 20px;
        }

        .otp-value {
          font-size: 36px;
          letter-spacing: 8px;
        }

        .header {
          padding: 28px 20px;
        }

        .header h1 {
          font-size: 22px;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <!-- Header -->
        <div class="header">
          <h1>Two-Factor Authentication</h1>
          <p>Secure verification required</p>
        </div>

        <!-- Content -->
        <div class="content">
          <div class="badge">🔐 Security Code</div>

          <div class="greeting">
            Hello
            <span>{{name}}</span>,
          </div>

          <div class="message">
            Please use the verification code below to complete your sign-in.
            This code adds an extra layer of security to your account.
          </div>

          <!-- OTP Card -->
          <div class="otp-card">
            <div class="otp-label">Verification Code</div>
            <div class="otp-value">{{otp}}</div>
            <div class="otp-expiry">⏰ Expires in 10 minutes</div>
          </div>

          <!-- Security Alert -->
          <div class="alert-box">
            <div class="alert-title">
              <span>🔔</span>
              Security Reminder
            </div>
            <ul class="alert-list">
              <li>Never share this code with anyone</li>
              <li>Our team will never ask for this code</li>
              <li>If you didn't request this, ignore this email</li>
            </ul>
          </div>

          <div class="divider"></div>

          <!-- Help Section -->
          <div class="help-text">
            <strong>Didn't request this?</strong>
            If you didn't try to sign in, someone may have your password.
            <a href="#">Secure your account →</a>
          </div>

          <div class="help-text" style="margin-top: 12px;">
            <strong>Need assistance?</strong>
            Contact our
            <a href="#">support team</a>
          </div>
        </div>

        <!-- Footer -->
        <div class="footer">
          <div class="footer-text">
            This email was sent to
            {{email}}
            for security verification
          </div>
          <div class="footer-text" style="margin-top: 12px;">
            ©
            {{currentYear}}
            Your Company. All rights reserved.
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
